---
// Decorative floating icon field for the hero slate panel
---

<div class="hero-icons" aria-hidden="true">

  <!-- Beer mug -->
  <svg class="hi hi-beer" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <rect x="18" y="34" width="48" height="50" rx="3"/>
    <path d="M66 44 Q84 44 84 60 Q84 76 66 76"
          fill="none" stroke="currentColor" stroke-width="9" stroke-linecap="round"/>
    <ellipse cx="30" cy="32" rx="8" ry="6"/>
    <ellipse cx="42" cy="29" rx="10" ry="7"/>
    <ellipse cx="55" cy="32" rx="7"  ry="5"/>
  </svg>

  <!-- Java / coffee cup -->
  <svg class="hi hi-java" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <path d="M24 40 L29 80 Q29 85 34 85 L66 85 Q71 85 71 80 L76 40Z"/>
    <ellipse cx="50" cy="88" rx="28" ry="4"/>
    <path d="M71 53 Q83 53 83 63 Q83 73 71 73"
          fill="none" stroke="currentColor" stroke-width="7" stroke-linecap="round"/>
    <path d="M38 32 Q36 25 38 18"
          fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
    <path d="M50 30 Q48 23 50 16"
          fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
  </svg>

  <!-- AWS cloud -->
  <svg class="hi hi-aws" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <ellipse cx="50" cy="56" rx="34" ry="20"/>
    <ellipse cx="36" cy="51" rx="18" ry="16"/>
    <ellipse cx="65" cy="49" rx="20" ry="17"/>
    <ellipse cx="50" cy="41" rx="22" ry="18"/>
    <ellipse cx="34" cy="83" rx="3.5" ry="5.5"/>
    <ellipse cx="50" cy="86" rx="3.5" ry="5.5"/>
    <ellipse cx="66" cy="83" rx="3.5" ry="5.5"/>
  </svg>

  <!-- Runner -->
  <svg class="hi hi-runner" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <circle cx="63" cy="16" r="9"/>
    <path d="M63 25 Q56 38 46 46"
          fill="none" stroke="currentColor" stroke-width="7"   stroke-linecap="round"/>
    <path d="M56 34 Q67 28 75 33"
          fill="none" stroke="currentColor" stroke-width="5.5" stroke-linecap="round"/>
    <path d="M52 41 Q44 53 38 60"
          fill="none" stroke="currentColor" stroke-width="5.5" stroke-linecap="round"/>
    <path d="M46 46 Q38 59 30 67 Q26 71 22 69"
          fill="none" stroke="currentColor" stroke-width="6.5" stroke-linecap="round"/>
    <path d="M46 46 Q53 59 57 69 Q59 75 55 79"
          fill="none" stroke="currentColor" stroke-width="6.5" stroke-linecap="round"/>
  </svg>

</div>

<style>
  .hero-icons {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hi {
    position: absolute;
    fill: rgba(255, 255, 255, 0.055);
    color: rgba(255, 255, 255, 0.055);
  }

  .hi-beer   { width: 340px; height: 340px; top: -50px;  right: -70px; animation: bob 16s ease-in-out infinite; }
  .hi-java   { width: 200px; height: 200px; bottom: 60px; right: 50px;  animation: bob 20s ease-in-out infinite 4s; }
  .hi-aws    { width: 260px; height: 260px; bottom: -70px; left: -50px; animation: bob 18s ease-in-out infinite 8s; }
  .hi-runner { width: 220px; height: 220px; top: 140px;  left: -40px;  animation: bob 22s ease-in-out infinite 2s; }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-14px); }
  }
</style>
