---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---

<BaseLayout title="blog" description="Writing on JVM internals, cloud architecture and developer tooling.">
  <PageHeader eyebrow="Writing" title="Blog" tagline="Things I think are interesting enough to write down." />

  <div class="blog-wrap fade-up-delay">
    {posts.length === 0 ? (
      <p class="empty-state">No posts yet — run <code class="code-inline">bun scripts/new-post.ts</code> to create one.</p>
    ) : (
      <>
        <div class="filters-wrap">
          <div class="filters" role="group" aria-label="Filter by tag">
            <button class="filter-btn active" data-tag="">All</button>
            {allTags.map((tag) => (
              <button class="filter-btn" data-tag={tag}>{tag}</button>
            ))}
          </div>
        </div>

        <ul class="post-list" id="post-list">
          {posts.map((post) => {
            const slug = post.id.replace('/index.md', '').replace('.md', '');
            return (
              <li data-tags={post.data.tags.join(',')}>
                <a href={`/blog/${slug}`} class="post-item">
                  <time class="post-date">{fmt(post.data.date)}</time>
                  <div class="post-body">
                    <div class="post-title">{post.data.title}</div>
                    <div class="post-desc">{post.data.description}</div>
                    <div class="post-tags">
                      {post.data.tags.map((t) => <span class="tag">{t}</span>)}
                    </div>
                  </div>
                  <span class="post-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            );
          })}
        </ul>

        <p class="no-results" id="no-results" hidden>No posts match that filter.</p>
      </>
    )}
  </div>
</BaseLayout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLLIElement>('#post-list li');
  const noResults = document.getElementById('no-results')!;

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      btns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      const tag = btn.dataset.tag ?? '';
      let visible = 0;
      items.forEach((li) => {
        const tags = li.dataset.tags?.split(',') ?? [];
        const show = tag === '' || tags.includes(tag);
        li.hidden = !show;
        if (show) visible++;
      });
      noResults.hidden = visible > 0;
    });
  });
</script>

<style>
  .blog-wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: 3.5rem 2rem 6rem;
  }

  .empty-state { font-size: 0.95rem; color: var(--fg-muted); }

  .code-inline {
    font-family: 'Fira Code', 'Cascadia Code', monospace;
    background: var(--bg-muted);
    padding: 0.1em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  /* ── Filters ── */
  .filters-wrap {
    position: relative;
    margin-bottom: 1.75rem;
  }

  .filters-wrap::after {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 3rem;
    background: linear-gradient(to right, transparent, var(--bg));
    pointer-events: none;
  }

  .filters {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.4rem;
    overflow-x: auto;
    padding-right: 3rem;
    padding-bottom: 2px;
    scrollbar-width: none;
  }
  .filters::-webkit-scrollbar { display: none; }

  .filter-btn {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 3px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--ease), border-color var(--ease), background var(--ease);
  }
  .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
  .filter-btn.active {
    background: rgba(232, 197, 71, 0.1);
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── Post list ── */
  .post-list { list-style: none; }

  .post-item {
    display: grid;
    grid-template-columns: 100px 1fr 20px;
    gap: 0 1.5rem;
    align-items: start;
    padding: 1.25rem 0.75rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius);
    margin: 0 -0.75rem;
    transition: background var(--ease);
  }
  .post-item:hover { background: var(--bg-hover); }
  .post-item:hover .post-title { color: var(--accent); }
  .post-item:hover .post-arrow { color: var(--accent); transform: translateX(var(--arrow-slide)); }

  .post-date {
    font-family: var(--font-head);
    font-weight: 500;
    font-size: 0.72rem;
    color: var(--fg-faint);
    padding-top: 0.25rem;
    white-space: nowrap;
  }

  .post-body { display: flex; flex-direction: column; }

  .post-title {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 1rem;
    color: var(--fg);
    margin-bottom: 0.3rem;
    line-height: 1.3;
    transition: color var(--ease);
  }

  .post-desc {
    font-size: 0.85rem;
    color: var(--fg-muted);
    line-height: 1.6;
  }

  .post-tags {
    display: flex;
    gap: 0.3rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .post-arrow {
    font-size: 0.9rem;
    color: var(--fg-faint);
    padding-top: 0.2rem;
    transition: color var(--ease), transform var(--ease);
  }

  .tag {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-dk);
    background: rgba(232, 197, 71, 0.08);
    border: 1px solid rgba(232, 197, 71, 0.2);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
  }

  .no-results { font-size: 0.88rem; color: var(--fg-faint); padding: 1rem 0; }

  @media (max-width: 600px) {
    .blog-wrap { padding: 2.5rem 1.25rem 4rem; }
    .post-item { grid-template-columns: 1fr; gap: 0.25rem; }
    .post-date { padding-top: 0; }
    .post-arrow { display: none; }
  }
</style>
