---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import meImg from '../../public/me.jpg';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---

<BaseLayout title="Joss Moffatt">
  <div class="page">

    <!-- ── Intro ── -->
    <section class="intro fade-up">
      <Image
        src={meImg}
        alt="Joss Moffatt"
        class="avatar"
        width={64}
        height={64}
        loading="eager"
        fetchpriority="high"
      />
      <div class="intro-body">
        <span class="eyebrow">Software Engineer</span>
        <h1>Joss Moffatt</h1>
        <p class="tagline">Scalable architectures, fast JVM libraries, and developer tooling.</p>
      </div>
    </section>

    <hr class="divider" />

    <!-- ── Me ── -->
    <!--
      Icons: Font Awesome Free 6.7.2 — https://fontawesome.com
      License: CC BY 4.0 — https://fontawesome.com/license/free
      Copyright 2024 Fonticons, Inc.
    -->
    <section class="fade-up-delay">
      <h2 class="section-title">Me</h2>
      <ul class="now-list">

        <li>
          <svg class="now-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" aria-hidden="true">
            <path d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z"/>
          </svg>
          <span>Based in Nottingham with my partner Erin.</span>
        </li>

        <li>
          <svg class="now-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" aria-hidden="true">
            <path d="M88 0C74.7 0 64 10.7 64 24c0 38.9 23.4 59.4 39.1 73.1l1.1 1C120.5 112.3 128 119.9 128 136c0 13.3 10.7 24 24 24s24-10.7 24-24c0-38.9-23.4-59.4-39.1-73.1l-1.1-1C119.5 47.7 112 40.1 112 24c0-13.3-10.7-24-24-24zM32 192c-17.7 0-32 14.3-32 32L0 416c0 53 43 96 96 96l192 0c53 0 96-43 96-96l16 0c61.9 0 112-50.1 112-112s-50.1-112-112-112l-48 0L32 192zm352 64l16 0c26.5 0 48 21.5 48 48s-21.5 48-48 48l-16 0 0-96zM224 24c0-13.3-10.7-24-24-24s-24 10.7-24 24c0 38.9 23.4 59.4 39.1 73.1l1.1 1C232.5 112.3 240 119.9 240 136c0 13.3 10.7 24 24 24s24-10.7 24-24c0-38.9-23.4-59.4-39.1-73.1l-1.1-1C231.5 47.7 224 40.1 224 24z"/>
          </svg>
          <span>Powered primarily by coffee. It's not a problem — I can quit any time.</span>
        </li>

        <li>
          <svg class="now-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" aria-hidden="true">
            <path d="M32 64c0-17.7 14.3-32 32-32l288 0c17.7 0 32 14.3 32 32l0 32 51.2 0c42.4 0 76.8 34.4 76.8 76.8l0 102.1c0 30.4-17.9 57.9-45.6 70.2L384 381.7l0 34.3c0 35.3-28.7 64-64 64L96 480c-35.3 0-64-28.7-64-64L32 64zM384 311.6l56.4-25.1c4.6-2.1 7.6-6.6 7.6-11.7l0-102.1c0-7.1-5.7-12.8-12.8-12.8L384 160l0 151.6zM160 144c0-8.8-7.2-16-16-16s-16 7.2-16 16l0 224c0 8.8 7.2 16 16 16s16-7.2 16-16l0-224zm64 0c0-8.8-7.2-16-16-16s-16 7.2-16 16l0 224c0 8.8 7.2 16 16 16s16-7.2 16-16l0-224zm64 0c0-8.8-7.2-16-16-16s-16 7.2-16 16l0 224c0 8.8 7.2 16 16 16s16-7.2 16-16l0-224z"/>
          </svg>
          <span>Balanced out with a beer. Everything in moderation, including moderation.</span>
        </li>

        <li>
          <svg class="now-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" aria-hidden="true">
            <path d="M499.1 6.3c8.1 6 12.9 15.6 12.9 25.7l0 72 0 264c0 44.2-43 80-96 80s-96-35.8-96-80s43-80 96-80c11.2 0 22 1.6 32 4.6L448 147 192 223.8l0 208.1c0 44.2-43 80-96 80s-96-35.8-96-80s43-80 96-80c11.2 0 22 1.6 32 4.6L128 200l0-72c0-14.1 9.3-26.6 22.8-30.7l320-96c9.7-2.9 20.2-1.1 28.3 5z"/>
          </svg>
          <span>Electronic music enthusiast. Yes, it counts as music.</span>
        </li>

        <li>
          <svg class="now-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" aria-hidden="true">
            <path d="M320 48a48 48 0 1 0 -96 0 48 48 0 1 0 96 0zM125.7 175.5c9.9-9.9 23.4-15.5 37.5-15.5c1.9 0 3.8 .1 5.6 .3L137.6 254c-9.3 28 1.7 58.8 26.8 74.5l86.2 53.9-25.4 88.8c-4.9 17 5 34.7 22 39.6s34.7-5 39.6-22l28.7-100.4c5.9-20.6-2.6-42.6-20.7-53.9L238 299l30.9-82.4 5.1 12.3C289 264.7 323.9 288 362.7 288l21.3 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-21.3 0c-12.9 0-24.6-7.8-29.5-19.7l-6.3-15c-14.6-35.1-44.1-61.9-80.5-73.1l-48.7-15c-11.1-3.4-22.7-5.2-34.4-5.2c-31 0-60.8 12.3-82.7 34.3L57.4 153.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l23.1-23.1zM91.2 352L32 352c-17.7 0-32 14.3-32 32s14.3 32 32 32l69.6 0c19 0 36.2-11.2 43.9-28.5L157 361.6l-9.5-6c-17.5-10.9-30.5-26.8-37.9-44.9L91.2 352z"/>
          </svg>
          <span>Runs distances that hurt and throws around weights that are, to me, objectively heavy.</span>
        </li>

      </ul>
    </section>

    <hr class="divider" />

    <!-- ── Writing ── -->
    <section class="fade-up-delay">
      <div class="section-header">
        <h2 class="section-title">Writing</h2>
        <a href="/blog" class="view-all">All posts →</a>
      </div>

      {recentPosts.length === 0 ? (
        <p class="empty">No posts yet.</p>
      ) : (
        <ul class="post-list">
          {recentPosts.map((post) => {
            const slug = post.id.replace('/index.md', '').replace('.md', '');
            return (
              <li>
                <a href={`/blog/${slug}`} class="post-row">
                  <time class="post-date">{fmt(post.data.date)}</time>
                  <div class="post-content">
                    <span class="post-title">{post.data.title}</span>
                    <span class="post-desc">{post.data.description}</span>
                  </div>
                  <span class="post-arrow">→</span>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </section>

    <hr class="divider" />

    <!-- ── Connect ── -->
    <section class="connect fade-up-delay">
      <h2 class="section-title">Connect</h2>
      <ul class="connect-list">
        <li><a href="https://github.com/jossmoff" target="_blank" rel="noopener">github</a></li>
        <li><a href="https://www.linkedin.com/in/joss-moffatt/" target="_blank" rel="noopener">linkedin</a></li>
        <li><a href="mailto:hi@joss.dev">hi@joss.dev</a></li>
        <li><a href="/resume">resume</a></li>
      </ul>
    </section>

  </div>
</BaseLayout>

<style>
  .page {
    max-width: 700px;
    margin: 0 auto;
    padding: 3.5rem 2rem 6rem;
  }

  /* ── Intro ── */
  .intro { display: flex; align-items: center; gap: 1.5rem; }

  .avatar {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid var(--border);
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .eyebrow {
    display: block;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }

  .intro-body h1 {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    letter-spacing: -0.03em;
    color: var(--fg);
    line-height: 1.1;
    margin-bottom: 0.35rem;
  }

  .tagline { font-size: 0.9rem; color: var(--fg-muted); line-height: 1.55; }

  /* ── Divider ── */
  .divider { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

  /* ── Section titles ── */
  .section-title {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-faint);
    margin-bottom: 1rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0;
  }

  .view-all {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.75rem;
    color: var(--fg-faint);
    text-decoration: none;
    transition: color var(--ease);
  }
  .view-all:hover { color: var(--accent); }

  /* ── Now ── */
  .now-list { list-style: none; display: flex; flex-direction: column; gap: 0.85rem; }

  .now-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    font-size: 0.9rem;
    color: var(--fg-muted);
    line-height: 1.65;
  }

  .now-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    fill: var(--accent);
    opacity: 0.55;
    margin-top: 0.28rem;
  }

  /* ── Writing ── */
  .post-list { list-style: none; margin-top: 0.25rem; }

  .post-row {
    display: grid;
    grid-template-columns: 88px 1fr 20px;
    gap: 0 1.25rem;
    align-items: start;
    padding: 1rem 0.75rem;
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    margin: 0 -0.75rem;
    transition: background var(--ease);
  }

  .post-row:hover { background: var(--bg-hover); }

  .post-date {
    font-family: var(--font-head);
    font-weight: 500;
    font-size: 0.7rem;
    color: var(--fg-faint);
    padding-top: 0.2rem;
    white-space: nowrap;
  }

  .post-content { display: flex; flex-direction: column; gap: 0.2rem; }

  .post-title {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--fg);
    line-height: 1.3;
    transition: color var(--ease);
  }

  .post-row:hover .post-title { color: var(--accent); }

  .post-desc { font-size: 0.8rem; color: var(--fg-faint); line-height: 1.5; }

  .post-arrow {
    font-size: 0.85rem;
    color: var(--fg-faint);
    padding-top: 0.2rem;
    transition: color var(--ease), transform var(--ease);
  }

  .post-row:hover .post-arrow {
    color: var(--accent);
    transform: translateX(var(--arrow-slide));
  }

  /* ── Connect ── */
  .connect-list { list-style: none; display: flex; gap: 1.5rem; flex-wrap: wrap; }

  .connect-list a {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color var(--ease);
  }
  .connect-list a:hover { color: var(--accent); }

  .empty { font-size: 0.88rem; color: var(--fg-faint); margin-top: 0.5rem; }

  @media (max-width: 600px) {
    .page { padding: 2.5rem 1.25rem 4rem; }
    .intro { gap: 1rem; }
    .post-row { grid-template-columns: 1fr; gap: 0.2rem; }
    .post-date { padding-top: 0; }
    .post-arrow { display: none; }
  }
</style>
